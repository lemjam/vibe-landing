generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  contact   String
  consent   Boolean
  createdAt DateTime @default(now())
}

model ConversionEvent {
  id        String   @id @default(uuid())
  type      String
  metadata  Json?
  createdAt DateTime @default(now())
}

model WebhookEvent {
  id         String   @id @default(uuid())
  externalId String   @unique
  payload    Json
  receivedAt DateTime @default(now())
}